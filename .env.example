# Copy this file to ".env" and paste your Anthropic API key below.
# Get a key at https://console.anthropic.com/  → API Keys.
# With a key set, CornerPost writes every post with real AI in the business's
# voice. Without one, it runs in demo mode using the built-in template engine.

ANTHROPIC_API_KEY=

# Which Claude model writes the posts.
# Default is Haiku 4.5 — fast and cheap (pennies per business per month),
# great for short social posts. For richer, more nuanced copy, use:
#   claude-opus-4-8   (highest quality)
#   claude-sonnet-5   (strong middle ground)
ANTHROPIC_MODEL=claude-haiku-4-5

# Port the app runs on.
PORT=3000
